# Server
PORT=3000

# Comma-separated list of allowed browser/app origins for CORS, e.g.:
# CORS_ORIGINS=http://localhost:8081,http://localhost:19006
# Omit or leave empty to allow all origins during development (not for production).
CORS_ORIGINS=

# Firebase Admin — pick ONE approach:
# 1) Path to a service account JSON file (also works with applicationDefault())
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/serviceAccount.json

# 2) OR paste the entire service account JSON as a single line (useful for some hosts)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
